generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Single-row table. Holds professional summary, resume link, and contact info.
// Use a fixed id (e.g. 1) so there is always exactly one profile.
model Profile {
  id          Int      @id @default(1)
  summary     String   // the one professional summary paragraph
  resumeUrl   String?  // link to downloadable resume PDF
  email       String
  phone       String?
  location    String?
  githubUrl   String?
  linkedinUrl String?
  websiteUrl  String?
  updatedAt   DateTime @updatedAt
}

model Skill {
  id       Int     @id @default(autoincrement())
  name     String
  category String? // e.g. "Frontend", "Backend", "Tools"
  order    Int     @default(0) // for manual sorting
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String   // hosted image URL (see note in setup)
  projectUrl  String?  // live demo link
  sourceUrl   String?  // repo link
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Certification {
  id            Int       @id @default(autoincrement())
  title         String
  issuer        String
  imageUrl      String    // certificate image URL
  credentialUrl String?   // verification link
  issuedAt      DateTime?
  order         Int       @default(0)
}
